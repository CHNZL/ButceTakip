# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE SIGN IN & FIREBASE:
# Google Auth / Cloud Sync için Google Sign-In gerekmektedir.
# Aşağıdaki bilgileri Firebase Console üzerinden veya Google Cloud Console'dan alabilirsiniz
WEB_CLIENT_ID=your_web_client_id_here
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
